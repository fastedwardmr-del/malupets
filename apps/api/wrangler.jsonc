{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api-malupets",
  "main": "src/index.js",
  "compatibility_date": "2026-07-07",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "malupets-db",
      "database_id": "4e961cb0-959c-40ab-8fea-1741eccb5a95"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "malupets-files"
    }
  ]
}
